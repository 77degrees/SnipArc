<Window x:Class="ScreenCaptureApp.App.RecognitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Extract text and codes — SnipArc"
        Width="680" Height="560" MinWidth="540" MinHeight="420"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="22">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="Extracted content" FontSize="24" FontWeight="SemiBold" />
      <TextBlock x:Name="SummaryText" Margin="0,4,0,14" Foreground="#686870" />
    </StackPanel>

    <TabControl Grid.Row="1">
      <TabItem Header="Text">
        <TextBox x:Name="TextBox" Margin="8" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 IsReadOnly="True" AutomationProperties.Name="Recognized text" />
      </TabItem>
      <TabItem Header="Barcodes">
        <ListView x:Name="BarcodeList" Margin="8" AutomationProperties.Name="Recognized barcodes">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="Format" Width="130" DisplayMemberBinding="{Binding Format}" />
              <GridViewColumn Header="Value" Width="430" DisplayMemberBinding="{Binding Text}" />
            </GridView>
          </ListView.View>
        </ListView>
      </TabItem>
      <TabItem Header="Translation">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock x:Name="TranslationHelp" TextWrapping="Wrap" Foreground="#686870"
                     Text="Translation is sent only when you press Translate. Configure a compatible HTTPS LibreTranslate endpoint in Settings." />
          <TextBox x:Name="TranslationBox" Grid.Row="1" Margin="0,10,0,0" AcceptsReturn="True"
                   TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"
                   AutomationProperties.Name="Translated text" />
        </Grid>
      </TabItem>
    </TabControl>

    <TextBlock Grid.Row="2" Margin="0,12,0,0" Foreground="#686870" TextWrapping="Wrap"
               Text="OCR and barcode recognition run locally. Translation is the only action on this window that can send extracted text over the network." />

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Copy" Click="Copy_Click" AutomationProperties.Name="Copy extracted content" />
      <Button x:Name="TranslateButton" Content="Translate" Click="Translate_Click"
              AutomationProperties.Name="Translate recognized text" />
      <Button Content="Close" IsCancel="True" />
    </StackPanel>
  </Grid>
</Window>
