<Window x:Class="ScreenCaptureApp.App.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture area" WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" Background="Black" Cursor="Cross" PreviewKeyDown="Window_KeyDown"
        UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display">
  <Window.Resources>
    <SolidColorBrush x:Key="ToolbarSurfaceBrush" Color="#F21D1F23" />
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="#5AFFFFFF" />
    <SolidColorBrush x:Key="ToolbarTextBrush" Color="#F2FFFFFF" />
    <SolidColorBrush x:Key="ToolbarMutedBrush" Color="#A6FFFFFF" />
    <SolidColorBrush x:Key="ToolbarHoverBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="ToolbarPressedBrush" Color="#38FFFFFF" />
    <SolidColorBrush x:Key="ToolbarAccentBrush" Color="#4C8DFF" />

    <Style x:Key="OverlayButton" TargetType="Button">
      <Setter Property="Width" Value="36" />
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Margin" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource ToolbarTextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ToolbarHoverBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ToolbarPressedBrush}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Chrome" Property="BorderBrush" Value="#C6D8FFFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.3" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource OverlayButton}">
      <Setter Property="Margin" Value="0,1" />
    </Style>

    <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource OverlayButton}">
      <Setter Property="Background" Value="{StaticResource ToolbarAccentBrush}" />
    </Style>

    <Style TargetType="ToolTip">
      <Setter Property="Background" Value="#F5212328" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#52FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="9,6" />
      <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Placement" Value="Mouse" />
      <Setter Property="HorizontalOffset" Value="12" />
      <Setter Property="VerticalOffset" Value="12" />
    </Style>

    <Style x:Key="CompactSlider" TargetType="Slider">
      <Setter Property="Width" Value="62" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Margin" Value="5,0,4,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid>
              <Border Height="3" Margin="5,0" Background="#4AFFFFFF" CornerRadius="2" VerticalAlignment="Center" />
              <Track x:Name="PART_Track" VerticalAlignment="Center">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge" Opacity="0" Focusable="False" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                  <Thumb Width="12" Height="12" Focusable="False">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="White" Stroke="#60000000" StrokeThickness="1" />
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge" Opacity="0" Focusable="False" />
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid x:Name="Root">
    <ContentControl x:Name="SurfaceHost" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
    <Canvas x:Name="OverlayCanvas">
      <Border x:Name="ToolPanel"
              Visibility="Hidden"
              Background="{StaticResource ToolbarSurfaceBrush}"
              BorderBrush="{StaticResource ToolbarBorderBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="4"
              IsHitTestVisible="True">
        <Border.Effect>
          <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.36" Color="#000000" />
        </Border.Effect>
        <StackPanel x:Name="ToolStack">
          <Button x:Name="SelectButton" Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Select"
                  Background="{StaticResource ToolbarAccentBrush}" ToolTip="Select or move area (V)" AutomationProperties.Name="Select or move area">
            <Viewbox Width="18" Height="18"><Path Data="M3,2 L3,17 L7.5,13 L11,19 L13.2,17.8 L9.8,12 L16,12 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Pen" ToolTip="Freehand pen (P)" AutomationProperties.Name="Freehand pen">
            <Viewbox Width="18" Height="18"><Path Data="M4,15.5 L5,11.5 L14.8,1.7 C15.5,1 16.6,1 17.3,1.7 L18.3,2.7 C19,3.4 19,4.5 18.3,5.2 L8.5,15 L4,15.5 Z M6,11.5 L8.5,14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Line" ToolTip="Line (L)" AutomationProperties.Name="Line">
            <Viewbox Width="18" Height="18"><Path Data="M3,17 L17,3" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Arrow" ToolTip="Arrow (A)" AutomationProperties.Name="Arrow">
            <Viewbox Width="18" Height="18"><Path Data="M3,10 L17,10 M12,5 L17,10 L12,15" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Rectangle" ToolTip="Rectangle (R)" AutomationProperties.Name="Rectangle">
            <Viewbox Width="18" Height="18"><Path Data="M3.5,4 L16.5,4 L16.5,16 L3.5,16 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeLineJoin="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Highlight" ToolTip="Highlighter (H)" AutomationProperties.Name="Highlighter">
            <Viewbox Width="18" Height="18"><Path Data="M6,3 L17,14 L13.5,17.5 L2.5,6.5 Z M4,17.5 L10,17.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Text" ToolTip="Text (T)" AutomationProperties.Name="Text">
            <Viewbox Width="18" Height="18"><Path Data="M4,4 L16,4 M10,4 L10,17 M7,17 L13,17" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Pixelate" ToolTip="Pixelate — visual obfuscation only (B)" AutomationProperties.Name="Pixelate, visual obfuscation only">
            <Viewbox Width="18" Height="18"><Path Data="M3,3 L8,3 L8,8 L3,8 Z M12,3 L17,3 L17,8 L12,8 Z M3,12 L8,12 L8,17 L3,17 Z M12,12 L17,12 L17,17 L12,17 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" /></Viewbox>
          </Button>
          <Button Style="{StaticResource ToolButton}" Click="Tool_Click" Tag="Redact" ToolTip="Opaque redaction (D)" AutomationProperties.Name="Opaque redaction">
            <Viewbox Width="18" Height="18"><Path Data="M3,5 L17,5 L17,15 L3,15 Z M6,8 L14,8 M6,11 L12,11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeLineJoin="Round" StrokeStartLineCap="Round" Fill="Transparent" /></Viewbox>
          </Button>
        </StackPanel>
      </Border>

      <Border x:Name="ActionPanel"
              Visibility="Hidden"
              Background="{StaticResource ToolbarSurfaceBrush}"
              BorderBrush="{StaticResource ToolbarBorderBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="4"
              IsHitTestVisible="True">
        <Border.Effect>
          <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.36" Color="#000000" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
          <Button x:Name="ColorButton" Style="{StaticResource OverlayButton}" Click="Color_Click" ToolTip="Change annotation color" AutomationProperties.Name="Change annotation color">
            <Grid Width="18" Height="18">
              <Ellipse x:Name="ColorSwatch" Fill="#E53935" Stroke="#D9FFFFFF" StrokeThickness="2" />
            </Grid>
          </Button>
          <Slider x:Name="WidthSlider" Style="{StaticResource CompactSlider}" Minimum="1" Maximum="12" Value="3"
                  TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="WidthSlider_ValueChanged"
                  ToolTip="Annotation width" AutomationProperties.Name="Annotation width" />
          <Border Width="1" Height="22" Margin="3,0" Background="#42FFFFFF" />
          <Button x:Name="UndoButton" Style="{StaticResource OverlayButton}" Click="Undo_Click" ToolTip="Undo (Ctrl+Z)" AutomationProperties.Name="Undo">
            <Viewbox Width="18" Height="18"><Path Data="M8,5 L3,9 L8,13 M4,9 L11,9 C15,9 17,11 17,15" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Button x:Name="RedoButton" Style="{StaticResource OverlayButton}" Click="Redo_Click" ToolTip="Redo (Ctrl+Y)" AutomationProperties.Name="Redo">
            <Viewbox Width="18" Height="18"><Path Data="M12,5 L17,9 L12,13 M16,9 L9,9 C5,9 3,11 3,15" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Border Width="1" Height="22" Margin="3,0" Background="#42FFFFFF" />
          <Button Style="{StaticResource PrimaryActionButton}" Click="Copy_Click" ToolTip="Copy (Ctrl+C)" AutomationProperties.Name="Copy">
            <Viewbox Width="18" Height="18"><Path Data="M7,6 L16,6 L16,16 L7,16 Z M4,13 L4,3 L13,3" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeLineJoin="Round" StrokeStartLineCap="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Button Style="{StaticResource OverlayButton}" Click="Save_Click" ToolTip="Quick save (Ctrl+S)" AutomationProperties.Name="Quick save">
            <Viewbox Width="18" Height="18"><Path Data="M4,3 L15,3 L17,5 L17,17 L3,17 L3,3 Z M6,3 L6,8 L14,8 L14,3 M7,17 L7,11 L13,11 L13,17" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" StrokeLineJoin="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Button Style="{StaticResource OverlayButton}" Click="SaveAs_Click" ToolTip="Save as (Ctrl+Shift+S)" AutomationProperties.Name="Save as">
            <Viewbox Width="18" Height="18"><Path Data="M10,3 L10,13 M6,9 L10,13 L14,9 M4,16 L16,16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" /></Viewbox>
          </Button>
          <Button Style="{StaticResource OverlayButton}" Click="Cancel_Click" ToolTip="Cancel (Esc)" AutomationProperties.Name="Cancel">
            <Viewbox Width="18" Height="18"><Path Data="M4,4 L16,16 M16,4 L4,16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7" StrokeStartLineCap="Round" /></Viewbox>
          </Button>
        </StackPanel>
      </Border>
    </Canvas>
  </Grid>
</Window>
